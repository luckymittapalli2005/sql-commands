#1 display all books
SELECT*FROM Books;

#2 dispay all authors from uk
SELECT*FROM authors WHERE country='united kingdom';

#3 find books that cost more than 500
SELECT title,price FROM Books WHERE price>500;

#4 show books published after 2000
SELECT title,published_year FROM Books WHERE published_year>2000;

#5 count total no.of books
SELECT COUNT(*)AS total_books FROM Books;

#6 find the avg price of book
SELECT AVG(price)AS average_price FROM  Books;

#7 find the most expensive books
SELECT title,price FROM Books WHERE price =(
SELECT MAX(price)FROM books);

#8 find the cheapest book
SELECT title,price FROM Books WHERE price =(
SELECT MIN(price)FROM books);

#9 display all books from fantacy
SELECT*FROM Books WHERE genre='fantasy';

#10 count books in each genre
SELECT genre,COUNT(*)AS total_books FROM Books GROUP BY genre;

#11 find total price of all books
SELECT SUM(price)AS total_book_value FROM Books;

#12 display books with authors names
SELECT b.title,a.author_name FROM Books b JOIN authors a ON b.author_id=a.author_id;

#13 find authors who wrote books on fantasy genre
SELECT DISTINCT a.author_name
FROM Authors a 
JOIN Books b
ON a.author_id = b.author_id
WHERE b.genre = 'Fantasy';

#14 find books written by indians authors
SELECT b.title ,a.author_name FROM Books b JOIN authors a ON b.author_id=a.author_id WHERE a.country ='india';
 
#15 find the no.of authors by country
SELECT country,COUNT(*)AS total_authors
FROM authors GROUP BY country;

#16  find average book price by gener
SELECT genre,AVG(price)AS avg_price
FROM books
GROUP BY genre;

#17 find the latest published books

SELECT title,published_year
FROM books
WHERE published_year =(
SELECT MAX(published_year)
FROM books);

# 18 find the published book before 1950
SELECT title,published_year
FROM books
WHERE published_year<1950;

# 19 find the authors whose books cost more than 600

SELECT DISTINCT a.author_name,b.price FROM authors a
JOIN books b
ON a.author_id = b.author_id
WHERE b.price>600;

# 20 display books sorted by price 
SELECT title,price
FROM books
ORDER BY price DESC;

# 21 display top 5 most expensive books 
SELECT title,price
FROM books 
ORDER BY price DESC
LIMIT 5;

# 22 find the total no.of books written by each  author 
SELECT a.author_name,COUNT(b.book_id)
AS total_books
FROM authors a JOIN books b
ON a.author_id = b.author_id
GROUP BY a.author_name;

# 23 find authors whose names start with 'J'
SELECT * FROM authors
WHERE author_name LIKE 'J%';

#24 find books containing the word'the'
SELECT * FROM Books
WHERE title LIKE '%the%';

#25 find the books price b/w 300 and 500
SELECT*FROM books
WHERE price BETWEEN 300 AND 500;

#26 find the second most expensive books
SELECT title,price
FROM books
ORDER by price DESC
LIMIT 1 OFFSET 1;

# 27 Find the genre having more than book
SELECT genre,COUNT(*)AS total_books FROM books
GROUP BY genre
Having COUNT(*)>1;

# 28 find the authors and title sorted alphabetically
SELECT a.author_name,b.title
FROM authors a 
JOIN books b
ON a.author_id=b.author_id
ORDER BY a.author_name ASC;

# 29 find the oldest published book
SELECT title,published_year
FROM books
ORDER BY published_year ASC LIMIT 1;

#30 calculate price difference from avg price
SELECT title,price,price-(SELECT AVG (price)FROM books)
as difference_from_avg
FROM books;
